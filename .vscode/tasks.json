{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build SolidWorks MCP App",
      "type": "shell",
      "command": "dotnet",
      "args": [
        "build",
        "${workspaceFolder}\\app\\SolidWorksMcpApp\\SolidWorksMcpApp.csproj",
        "--no-incremental"
      ],
      "problemMatcher": "$msCompile",
      "group": "build"
    },
    {
      "label": "Start SolidWorks MCP App",
      "type": "shell",
      "command": "${workspaceFolder}\\app\\SolidWorksMcpApp\\bin\\Debug\\net8.0-windows\\win-x64\\SolidWorksMcpApp.exe",
      "isBackground": true,
      "problemMatcher": []
    }
  ]
}