{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Launch SolidWorks MCP Tray",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "Build SolidWorks MCP App",
      "program": "${workspaceFolder}/app/SolidWorksMcpApp/bin/Debug/net8.0-windows/win-x64/SolidWorksMcpApp.dll",
      "cwd": "${workspaceFolder}/app/SolidWorksMcpApp",
      "console": "internalConsole",
      "stopAtEntry": false,
      "justMyCode": true
    }
  ]
}