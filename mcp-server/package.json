{
  "name": "solidworks-mcp-server",
  "version": "0.1.0",
  "description": "MCP server for SolidWorks automation via Named Pipes bridge",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:acceptance": "vitest run --testTimeout 240000 --hookTimeout 240000 tests/acceptance/mcp-tools.acceptance.test.ts",
    "test:watch": "vitest"
  },
  "keywords": ["mcp", "solidworks", "cad", "automation"],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.8.0",
    "vitest": "^3.1.0"
  }
}
